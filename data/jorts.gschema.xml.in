<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <enum id="@APP_ID@.list-prefix">
    <value value='0' nick="disabled"/>
    <value value='1' nick="bullet"/>
    <value value='2' nick="dash"/>
    <value value='3' nick="wave"/>
    <value value='4' nick="dot"/>
  </enum>

  <schema path="@APP_PATH@/" id="@APP_ID@">
		<key name="scribbly-mode-active" type="b">
			<default>false</default>
			<summary>Change font to an illegible one</summary>
			<description>Whether to change font to an illegible one for unfocused sticky notes, for privacy</description>
		</key>
		<key name="hide-bar" type="b">
			<default>false</default>
			<summary>Hide actionbar</summary>
			<description>Whether to hide the actionbar and its buttons</description>
		</key>
		<key enum="@APP_ID@.list-prefix" name="list-prefix">
      		<default>'bullet'</default>
      		<summary>List item prefix</summary>
      		<description>The string to use at the start of a list item</description>
    	</key>
	</schema>
</schemalist>
